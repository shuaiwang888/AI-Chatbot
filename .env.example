# ========== LLM Provider ==========
# 默认 minimax (MiniMax-M3, OpenAI 兼容). 可切换: "openai" | "anthropic" | "qwen"
LLM_PROVIDER=minimax

# MiniMax-M3 配置 (OpenAI 兼容协议)
MINIMAX_API_KEY=your-api-key-here
MINIMAX_BASE_URL=https://api.MiniMax.com/v1
MINIMAX_MODEL=MiniMax-M3

# 可选：其他 LLM 备用 (切换 LLM_PROVIDER 时生效)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
QWEN_API_KEY=

# ========== Embedding & Reranker ==========
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
EMBEDDING_DEVICE=cpu              # cpu | cuda
USE_FP16=true                     # CPU 上 fp16 自动降级为 fp32

# ========== 向量库 / ChromaDB ==========
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=docs
ENABLE_COLBERT=true               # 三路融合开关 (false 则仅 dense+sparse)

# ========== 持久化 (HF Dataset repo) ==========
HF_PERSIST_REPO=                  # 形如 "username/ai-chatbot-data". 留空则禁用持久化
HF_TOKEN=                         # HuggingFace 写权限 token
PERSIST_ON_WRITE=true             # 每次写入后异步推送

# ========== 数据目录 ==========
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
SQLITE_DIR=./data/sqlite

# ========== RAG / Agent ==========
CHUNK_SIZE=512
CHUNK_OVERLAP=64
SEMANTIC_CHUNKING=true
CONTEXTUAL_RETRIEVAL=true         # Anthropic-style 上下文预置 (消耗少量 LLM token)
RETRIEVAL_K=20
RERANK_TOP_N=5
CRAG_MAX_ITERATIONS=2
CRAG_RELEVANCE_THRESHOLD=0.7

# ========== LLM 缓存 ==========
LLM_CACHE_ENABLED=true
LLM_CACHE_SIZE=200

# ========== LLM judge 备用模型 (可选) ==========
LLM_JUDGE_MODEL=MiniMax-M3        # CRAG evaluate 阶段 2 用

# ========== 解析器选择 ==========
PARSER_PRIMARY=docling            # docling | marker | mineru | vlm
PARSER_FALLBACK=marker
PARSER_ENABLE_OCR=true
PARSER_TABLE_STRUCTURE=true

# ========== 可观测性 ==========
LANGSMITH_TRACING=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-chatbot

# ========== CORS ==========
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
# 生产环境示例 (GitHub Pages):
# ALLOWED_ORIGINS=["https://yourname.github.io"]

# ========== 应用 ==========
APP_NAME=ai-chatbot
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=7860
LOG_LEVEL=INFO
