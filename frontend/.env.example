# 后端 API 地址
# - 本地 dev: 留空, vite proxy 会转发 /api 到 VITE_DEV_API_BASE
# - 生产 (GH Pages): 填入完整后端 URL, 末尾不带 /
#   例: https://yourname-ai-chatbot.hf.space/api/v1
VITE_API_BASE=

# Vite proxy 目标 (仅本地 dev 用), 默认 http://localhost:7860
VITE_DEV_API_BASE=http://localhost:7860

# GitHub 仓库名 (用于 base path), 形如 "yourname/ai-chatbot" → base="/ai-chatbot/"
# 也可以只填仓库名 "ai-chatbot"
VITE_REPO_NAME=ai-chatbot
